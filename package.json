{
  "name": "software-sawit",
  "version": "1.0.0",
  "description": "Desktop application for managing plantation financial data",
  "main": "dist/main/main.js",
  "author": "SoftwareSawit Team",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "tsc -p tsconfig.main.json && electron . --dev",
    "dev:renderer": "vite",
    "dev:user-mgmt": "vite build --config vite.user-mgmt.config.ts && tsc -p tsconfig.main.json && cross-env PORT=5174 electron . --dev",
    "build": "npm run build:renderer && npm run build:main",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "build:user-mgmt": "vite build --config vite.user-mgmt.config.ts",
    "start": "cross-env NODE_ENV=production electron .",
    "start:user-mgmt": "cross-env NODE_ENV=production PORT=5174 electron .",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "jest --passWithNoTests"
  },
  "dependencies": {
    "@types/bcryptjs": "^2.4.6",
    "bcryptjs": "^3.0.3",
    "electron-log": "^5.2.4",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "sql.js": "^1.14.1",
    "uuid": "^11.0.5",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/bcrypt": "^6.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/sql.js": "^1.4.9",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "cross-env": "^10.1.0",
    "electron": "^34.0.2",
    "electron-builder": "^25.1.8",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "jest": "^30.3.0",
    "postcss": "^8.4.49",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.17",
    "ts-jest": "^29.4.9",
    "typescript": "^5.7.3",
    "vite": "^8.0.0"
  },
  "build": {
    "appId": "com.softwaresawit.app",
    "productName": "SoftwareSawit",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "data/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
